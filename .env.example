# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=         # From @BotFather
TELEGRAM_MY_CHAT_ID=        # From @userinfobot (your numeric user ID)

# ── Anthropic ─────────────────────────────────────────
ANTHROPIC_API_KEY=          # sk-ant-api03-...

# ── Your email addresses (filters sent mail + CC detection) ──────────────
PERSONAL_EMAIL=                 # your personal Gmail address

# ── Google (credentials.json handles OAuth, run `npm run setup` first) ──
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./data/google-token.json

# ── Canvas LMS ────────────────────────────────────────
CANVAS_BASE_URL=            # e.g. https://yourschool.instructure.com
CANVAS_API_TOKEN=           # From Canvas > Settings > Approved Integrations

# ── Microsoft Teams ───────────────────────────────────
TEAMS_ENABLED=false         # Set to true and add Azure creds to enable

# ── OpenWeatherMap ────────────────────────────────────
OPENWEATHERMAP_API_KEY=     # From openweathermap.org
WEATHER_LAT=33.4484
WEATHER_LON=-112.0740
WEATHER_UNITS=imperial      # imperial or metric

# ── App Config ────────────────────────────────────────
NODE_ENV=production
PORT=3000
TIMEZONE=America/Phoenix
LOG_LEVEL=info
DB_PATH=./data/jarvis.db
