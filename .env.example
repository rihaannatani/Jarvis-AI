# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=         # From @BotFather
TELEGRAM_MY_CHAT_ID=        # From @userinfobot (your numeric user ID)

# ── Anthropic ─────────────────────────────────────────
ANTHROPIC_API_KEY=          # sk-ant-api03-...
MODEL_SMART=claude-sonnet-4-6           # Conversations, briefs, drafts
MODEL_FAST=claude-haiku-4-5-20251001    # Email scoring, formatting (~20x cheaper)

# ── Your email addresses (filters sent mail + CC detection) ──────────────
PERSONAL_EMAIL=                 # your personal Gmail address
USER_NAME=Rihaan                # first name — used to sign email drafts

# ── Google (credentials.json handles OAuth, run `npm run setup` first) ──
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./data/google-token.json

# ── Canvas LMS ────────────────────────────────────────
CANVAS_BASE_URL=            # e.g. https://yourschool.instructure.com
CANVAS_API_TOKEN=           # From Canvas > Settings > Approved Integrations

# ── Microsoft Teams ───────────────────────────────────
TEAMS_ENABLED=false         # Set to true and add Azure creds to enable

# ── ASU Workday job scanning/apply ─────────────────────
WORKDAY_ENABLED=false       # Off by default; a separate external automation handles this

# ── OpenWeatherMap ────────────────────────────────────
OPENWEATHERMAP_API_KEY=     # From openweathermap.org
WEATHER_LAT=33.4484
WEATHER_LON=-112.0740
WEATHER_UNITS=imperial      # imperial or metric

# ── App Config ────────────────────────────────────────
NODE_ENV=production
PORT=3000
TIMEZONE=America/Phoenix
LOG_LEVEL=info
DB_PATH=./data/jarvis.db

# ── Location webhook (phone automation → location-triggered reminders) ──
# Off by default. If enabled, opens an HTTP server on PORT with a single
# endpoint: POST /webhook/location, body { secret, event, place }.
# Generate a secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_ENABLED=false
WEBHOOK_SECRET=
